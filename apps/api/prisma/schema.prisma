// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Title {
  MR
  MRS
  MS
  DR
  PROF
  LORD
  LADY
  REV
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum Country {
  ENGLAND
  WALES
  NORTHERN_IRELAND
}

enum DebtRange {
  LESS_THAN_5000
  BETWEEN_5000_AND_20000
  GREATER_THAN_20000
}

model User {
  id           String    @id @default(uuid())
  userId       String    @unique // e.g. TIGCAP6003352
  title        Title
  firstName    String
  lastName     String
  gender       Gender
  phone        String
  email        String    @unique
  country      Country
  debtRange    DebtRange
  passwordHash String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("users")
}
