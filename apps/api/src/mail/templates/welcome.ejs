<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8" />
    <style>
        body {
            font-family: Arial, sans-serif;
            color: #333;
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }

        .header {
            background-color: #1a1a2e;
            color: white;
            padding: 20px;
            border-radius: 8px 8px 0 0;
        }

        .body {
            background-color: #f9f9f9;
            padding: 30px;
            border: 1px solid #ddd;
        }

        .credentials {
            background: #fff;
            border: 1px solid #e0e0e0;
            border-radius: 6px;
            padding: 16px;
            margin: 20px 0;
        }

        .credentials table {
            width: 100%;
            border-collapse: collapse;
        }

        .credentials td {
            padding: 8px 12px;
        }

        .credentials td:first-child {
            font-weight: bold;
            color: #555;
            width: 120px;
        }

        .btn {
            display: inline-block;
            margin-top: 20px;
            padding: 12px 24px;
            background-color: #1a1a2e;
            color: white;
            text-decoration: none;
            border-radius: 6px;
        }

        .footer {
            font-size: 12px;
            color: #999;
            margin-top: 20px;
            text-align: center;
        }
    </style>
</head>

<body>
    <div class="header">
        <h2 style="margin:0;">The Insolvency Group</h2>
    </div>

    <div class="body">
        <p>Dear <strong>
                <%= firstName %>
            </strong>,</p>

        <p>Thank you for registering.</p>

        <p>Please login with the below details:</p>

        <div class="credentials">
            <table>
                <tr>
                    <td>UserId :</td>
                    <td><strong>
                            <%= userId %>
                        </strong></td>
                </tr>
                <tr>
                    <td>Password :</td>
                    <td><strong>
                            <%= password %>
                        </strong></td>
                </tr>
            </table>
        </div>

        <p>To access your application please use the following url:-</p>

        <a href="<%= loginUrl %>" class="btn">Access Application</a>

        <p style="margin-top: 30px;">With Regards,<br />The Insolvency Group</p>
    </div>

    <div class="footer">
        <p>Please do not reply to this email as the mailbox is not monitored.</p>
    </div>
</body>

</html>