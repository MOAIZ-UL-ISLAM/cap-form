<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background: #0d1b2a;
            margin: 0;
            padding: 40px 20px
        }

        .card {
            background: #162032;
            max-width: 560px;
            margin: 0 auto;
            border-radius: 8px;
            border: 1px solid #243447;
            overflow: hidden
        }

        .header {
            background: #1e2e42;
            padding: 28px 32px;
            border-bottom: 2px solid #c9a84c
        }

        .logo {
            font-size: 20px;
            font-weight: 700;
            letter-spacing: 2px;
            color: #fff
        }

        .logo span {
            color: #c9a84c
        }

        .body {
            padding: 32px
        }

        .label {
            font-size: 11px;
            color: #8a9ab0;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 20px
        }

        h2 {
            color: #fff;
            font-size: 20px;
            margin: 0 0 12px
        }

        p {
            color: #8a9ab0;
            font-size: 14px;
            line-height: 1.7;
            margin: 0 0 16px
        }

        .btn {
            display: inline-block;
            padding: 13px 28px;
            background: #c9a84c;
            color: #0d1b2a;
            font-weight: 700;
            font-size: 14px;
            text-decoration: none;
            border-radius: 6px;
            margin: 8px 0 24px
        }

        .notice {
            background: #0d1b2a;
            border-radius: 6px;
            padding: 14px 16px;
            font-size: 12px;
            color: #8a9ab0;
            border-left: 3px solid #c9a84c
        }

        .footer {
            padding: 20px 32px;
            font-size: 11px;
            color: #4a5a6a;
            border-top: 1px solid #243447
        }
    </style>
</head>

<body>
    <div class="card">
        <div class="header">
            <div class="logo"><span>TIG</span>CAP Portal</div>
        </div>
        <div class="body">
            <div class="label">Account Activation</div>
            <h2>Hello <%= firstName %>,</h2>
            <p>Your account has been created on the TIGCAP Insolvency Portal. Click below to activate your account and
                set your password.</p>
            <a href="<%= activationUrl %>" class="btn">Activate My Account</a>
            <div class="notice">⏱ This link expires in <strong>72 hours</strong>. If you did not expect this, please
                ignore it.</div>
        </div>
        <div class="footer">© <%= new Date().getFullYear() %> The Insolvency Group. Authorised by the IPA.</div>
    </div>
</body>

</html>